@prefix muAccount: <http://mu.semte.ch/vocabularies/account/> .
@prefix mu:        <http://mu.semte.ch/vocabularies/core/> .
@prefix foaf:      <http://xmlns.com/foaf/0.1/> .
@prefix ext:       <http://mu.semte.ch/vocabularies/ext/> .
@prefix rdf:       <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

<http://mu.semte.ch/graphs/automatic-submission> {
  <http://example.com/vendor/mechelen>
    rdf:type foaf:Agent ,
             ext:Vendor ;
    muAccount:key "mechelen-secret-key" ;
    muAccount:canActOnBehalfOf <http://data.lblod.info/id/bestuurseenheden/28346950e285b8b816133fece5ac9408097c3f190c7f32573cf0c640d6c34b1a> ;
    foaf:name "Mechelen vendor" ;
    mu:uuid "aaaa-bbbb-cccc-1111-2222-3333" .
}

